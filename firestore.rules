rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função auxiliar para verificar se usuário está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Função para verificar se é admin
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Função para verificar se é o próprio usuário
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Coleção de admins (gestão multi-admin)
    match /admins/{adminId} {
      allow read: if true;
      // Admin pode criar seu próprio documento no cadastro (quando adminId == request.auth.uid)
      // Admins existentes podem atualizar/deletar outros admins
      allow create: if isAuthenticated() && request.auth.uid == adminId;
      allow update, delete: if isAdmin();
      
      // ============================================================================
      // SUBCOLEÇÃO: clientes de cada admin
      // ============================================================================
      match /clientes/{clienteId} {
        // Admin pode ler e escrever seus próprios clientes
        // O request.auth.uid deve ser o ID do admin na coleção admins
        allow read, write: if isAdmin() && 
                              request.auth.uid == adminId;
      }
      
      // ============================================================================
      // SUBCOLEÇÃO: serviços específicos de cada admin
      // ============================================================================
      match /servicos/{servicoId} {
        // Admin pode gerenciar seus próprios serviços
        allow read, write: if isAdmin() && request.auth.uid == adminId;
        // Clientes podem ler os serviços do admin
        allow read: if isAuthenticated();
      }
    }
    
    // Documento especial para clientes órfãos (sem admin)
    match /admins/orphans {
      allow read: if true;
      allow write: if isAuthenticated();
      
      match /clientes/{clienteId} {
        // Qualquer usuário autenticado pode criar seu próprio registro de órfão
        // Admin pode ler e mover órfão para sua coleção
        allow read, write: if isAuthenticated();
      }
    }
    
    // Coleção de usuários
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if false;
    }
    
    // ============================================================================
    // COLEÇÃO: clientes (todos os clientes, com ou sem adminId)
    // ============================================================================
    match /clientes/{clienteId} {
      // Cliente pode criar seu próprio documento (quando se registra)
      allow create: if isAuthenticated() && request.auth.uid == clienteId;
      // Admin pode ler e escrever todos os clientes
      allow read, write: if isAdmin();
      // Cliente pode ler seu próprio documento
      allow read: if isAuthenticated() && request.auth.uid == clienteId;
      // Cliente pode atualizar seu próprio documento (em breve)
      allow update: if isAuthenticated() && request.auth.uid == clienteId;
    }    // Coleção de solicitações
    match /solicitacoes/{solicitacaoId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || 
                     (isAuthenticated() && resource.data.clienteId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
    
    // Coleção de solicitações de clientes
    match /solicitacoes_clientes/{solicitacaoId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && 
                     (isAdmin() || resource.data.clienteId == request.auth.uid);
      allow update: if isAuthenticated() && 
                       (isAdmin() || resource.data.clienteId == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    // Coleção de propostas
    match /propostas/{propostaId} {
      allow read: if isAdmin() || 
                     (isAuthenticated() && resource.data.clienteId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }
    
    // Coleção de contratos
    match /contratos/{contratoId} {
      allow read: if isAdmin() || 
                     (isAuthenticated() && resource.data.clienteId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin() || 
                       (isAuthenticated() && 
                        resource.data.clienteId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ============================================================================
    // COLEÇÃO: transacoes (financeiro - receitas e despesas)
    // ============================================================================
    match /transacoes/{transacaoId} {
      // Apenas admins podem criar, ler, atualizar e deletar transações
      allow read, write: if isAdmin();
    }

    // ============================================================================
    // COLEÇÃO: contratos_assinados (PDF e assinatura salvos pelo cliente)
    // ============================================================================
    match /contratos_assinados/{contratoId} {
      // Cliente pode criar quando assina contrato
      allow create: if isAuthenticated();
      // Cliente pode ler seus próprios contratos, admin pode ler todos
      allow read: if isAdmin() || 
                     (isAuthenticated() && resource.data.clienteId == request.auth.uid);
      // Apenas admin pode atualizar/deletar
      allow update, delete: if isAdmin();
    }
    
    // Coleção de projetos
    match /projetos/{projetoId} {
      allow read: if isAuthenticated() && 
                     (isAdmin() || 
                      resource.data.clienteId == request.auth.uid);
      allow create, update, delete: if isAdmin();
      
      // Permitir acesso a subcoleções do projeto (tasks, arquivos, etc)
      match /{subCollection=**} {
        allow read: if isAuthenticated() && 
                       (isAdmin() || 
                        get(/databases/$(database)/documents/projetos/$(projetoId)).data.clienteId == request.auth.uid);
        allow write: if isAdmin();
      }
    }
    
    // Coleção de portfólio
    match /portfolio/{portfolioId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Coleção de serviços
    match /servicos/{servicoId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Coleção de catálogo de serviços
    match /servicos_catalogo/{servicoId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Coleção financeira
    match /financeiro/{transacaoId} {
      allow read, write: if isAdmin();
    }
    
    // Coleção de social media
    match /socialMedia/{postId} {
      allow read, write: if isAdmin();
    }
    
    // Coleção de agenda - PERMITE USUÁRIOS AUTENTICADOS GERENCIAR SEUS PRÓPRIOS EVENTOS
    match /agenda/{eventoId} {
      // Qualquer usuário autenticado pode criar eventos
      allow create: if isAuthenticated();
      
      // Usuário pode ler seus próprios eventos, admin pode ler todos
      allow read: if isAuthenticated() && 
                     (isAdmin() || resource.data.adminId == request.auth.uid);
      
      // Usuário pode atualizar/deletar seus próprios eventos
      allow update, delete: if isAuthenticated() && 
                               (isAdmin() || resource.data.adminId == request.auth.uid);
    }
    
    // Notificações
    match /notificacoes/{notificacaoId} {
      allow read: if isAuthenticated() && 
                     (resource.data.destinatarioId == request.auth.uid || 
                      resource.data.destinatarioTipo == 'admin');
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
                       (resource.data.destinatarioId == request.auth.uid ||
                        resource.data.destinatarioTipo == 'admin') &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lida', 'lidaEm']);
      allow delete: if isAdmin();
    }
    
    // Timeline de atividades
    match /timeline/{atividadeId} {
      allow read, write: if isAdmin();
    }
    
    // Chat messages
    match /chat_messages/{messageId} {
      allow read, write: if isAuthenticated();
    }
  }
}
