rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função auxiliar para verificar se usuário está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Função para verificar se é admin
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Função para verificar se é o próprio usuário
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Coleção de admins (gestão multi-admin)
    match /admins/{adminId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
      
      // ============================================================================
      // SUBCOLEÇÃO: clientes de cada admin
      // ============================================================================
      match /clientes/{clienteId} {
        // Admin pode gerenciar seus clientes
        allow read, write: if isAuthenticated() && request.auth.uid == adminId;
      }
    }
    
    // Coleção de usuários
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isAdmin() || isOwner(userId);
      allow delete: if false;
    }    // Coleção de solicitações
    match /solicitacoes/{solicitacaoId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || 
                     (isAuthenticated() && resource.data.clienteId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
    
    // Coleção de solicitações de clientes
    match /solicitacoes_clientes/{solicitacaoId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || 
                     (isAuthenticated() && resource.data.clienteId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
    
    // Coleção de propostas
    match /propostas/{propostaId} {
      allow read: if isAdmin() || 
                     (isAuthenticated() && resource.data.clienteId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }
    
    // Coleção de contratos
    match /contratos/{contratoId} {
      allow read: if isAdmin() || 
                     (isAuthenticated() && resource.data.clienteId == request.auth.uid);
      allow update: if isAdmin() || 
                       (isAuthenticated() && 
                        resource.data.clienteId == request.auth.uid && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assinado', 'dataAssinatura']));
      allow create, delete: if isAdmin();
    }
    
    // Coleção de projetos
    match /projetos/{projetoId} {
      allow read: if isAdmin() || 
                     (isAuthenticated() && resource.data.clienteId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }
    
    // Coleção de portfólio
    match /portfolio/{portfolioId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Coleção de serviços
    match /servicos/{servicoId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Coleção financeira
    match /financeiro/{transacaoId} {
      allow read, write: if isAdmin();
    }
    
    // Coleção de social media
    match /socialMedia/{postId} {
      allow read, write: if isAdmin();
    }
    
    // Coleção de agenda - PERMITE USUÁRIOS AUTENTICADOS GERENCIAR SEUS PRÓPRIOS EVENTOS
    match /agenda/{eventoId} {
      // Qualquer usuário autenticado pode criar eventos
      allow create: if isAuthenticated();
      
      // Usuário pode ler seus próprios eventos, admin pode ler todos
      allow read: if isAuthenticated() && 
                     (isAdmin() || resource.data.adminId == request.auth.uid);
      
      // Usuário pode atualizar/deletar seus próprios eventos
      allow update, delete: if isAuthenticated() && 
                               (isAdmin() || resource.data.adminId == request.auth.uid);
    }
    
    // Notificações
    match /notificacoes/{notificacaoId} {
      allow read: if isAuthenticated() && 
                     (resource.data.destinatarioId == request.auth.uid || 
                      resource.data.destinatarioTipo == 'admin');
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
                       (resource.data.destinatarioId == request.auth.uid ||
                        resource.data.destinatarioTipo == 'admin') &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lida', 'lidaEm']);
      allow delete: if isAdmin();
    }
    
    // Timeline de atividades
    match /timeline/{atividadeId} {
      allow read, write: if isAdmin();
    }
    
    // Chat messages
    match /chat_messages/{messageId} {
      allow read, write: if isAuthenticated();
    }
  }
}
